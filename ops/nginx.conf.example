# Nginx configuration for Deliverty
# Install: sudo cp ops/nginx.conf.example /etc/nginx/sites-available/deliverty
# Enable: sudo ln -s /etc/nginx/sites-available/deliverty /etc/nginx/sites-enabled/
# SSL: sudo certbot --nginx -d your.domain

server {
  listen 80;
  server_name your.domain;

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen 443 ssl http2;
  server_name your.domain;

  ssl_certificate /etc/letsencrypt/live/your.domain/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/your.domain/privkey.pem;

  # API endpoints
  location /api/ {
    proxy_pass http://127.0.0.1:8080/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Bot webhook
  location /bot/ {
    proxy_pass http://127.0.0.1:8080/bot/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Frontend static files
  location / {
    root /srv/deliverty-frontend;
    try_files $uri /index.html;
  }

  # Security headers
  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header X-XSS-Protection "1; mode=block" always;
}





